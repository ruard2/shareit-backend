# Kopieer dit bestand naar .env en vul echte waarden in.
# Genereer sleutels met: python -c "import secrets; print(secrets.token_hex(32))"

# ── Database ──────────────────────────────────────────────────────────────
# Lokaal (SQLite — eenvoudig, niet geschikt voor productie):
DATABASE_URL=sqlite:///./app.db

# Productie (PostgreSQL — aanbevolen):
# DATABASE_URL=postgresql://gebruiker:wachtwoord@localhost:5432/spullen_db
# Heroku/Render geven soms "postgres://" — de app corrigeert dit automatisch.

# ── Beveiliging ───────────────────────────────────────────────────────────
SECRET_KEY=vervang_dit_met_een_willekeurige_sleutel_van_64_tekens
SESSION_SECRET=vervang_dit_met_een_andere_willekeurige_sleutel_van_64_tekens

# ── E-mail (voor PIN-reset) ───────────────────────────────────────────────
# Weglaten = dev-modus (reset-code wordt alleen naar de console geprint).
# Voor productie: vul deze in met je SMTP-gegevens.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jouw@email.nl
SMTP_PASSWORD=jouw_app_wachtwoord
# SMTP_FROM=Spullen Delen <noreply@jouwdomein.nl>
